plot_trait_heatmap_TNR_Bold <- function(MEs_use, traitNum, prefix){
  if (is.null(traitNum) || ncol(traitNum) == 0) return(invisible(NULL))
  
  cmat <- cor(MEs_use, traitNum, use = "p")
  pmat <- corPvalueStudent(cmat, nrow(MEs_use))
  textMatrix <- paste(signif(cmat, 2), "\n(",
                      signif(pmat, 1), ")", sep = "")
  dim(textMatrix) <- dim(cmat)
  
  open_svg(paste0(prefix, "_TNR_Bold.svg"), width = 11, height = 8)
  par(cex = 0.95)
  par(mar = mar_heat)
  par(family = "TNR", font = 2)  # 再保险一次
  
  labeledHeatmap(
    Matrix = cmat,
    xLabels = colnames(traitNum),
    yLabels = colnames(MEs_use),
    ySymbols = colnames(MEs_use),
    colorLabels = FALSE,
    colors = blueWhiteRed(50),
    textMatrix = textMatrix,
    setStdMargins = FALSE,
    cex.text = 0.85,     # 热图格子文字（你嫌小就继续调大）
    zlim = c(-1, 1),
    main = prefix
  )
  close_dev()
  
  invisible(list(cor = cmat, p = pmat))
}


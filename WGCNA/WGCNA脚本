msg <- function(...) cat(format(Sys.time(), "[%F %T] "), sprintf(...), "\n", sep="")

fix_path <- function(x){
  if (is.null(x) || length(x) == 0 || is.na(x) || x == "") return("")
  x <- as.character(x)
  x <- gsub("[\r\n\t]", "", x)
  x
}

read_featurecounts <- function(path){
  msg("Reading featureCounts table: %s", path)
  dt <- fread(path, data.table = FALSE)
  if (ncol(dt) <= 6) stop("featureCounts table columns <=6, invalid input.")
  
  gene_col <- which(tolower(colnames(dt)) %in% c("geneid","gene_id","geneid."))
  if (length(gene_col) != 1) gene_col <- 1
  gene_ids <- dt[[gene_col]]
  
  count_df <- dt[, 7:ncol(dt), drop = FALSE]
  colnames(count_df) <- sub("\\.bam$", "", colnames(count_df))
  
  count_mat <- as.matrix(count_df)
  suppressWarnings(storage.mode(count_mat) <- "integer")
  rownames(count_mat) <- gene_ids
  
  if (any(duplicated(rownames(count_mat)))) {
    msg("Duplicated Geneid found -> merging by sum.")
    count_mat <- rowsum(count_mat, group = rownames(count_mat))
  }
  
  count_mat <- count_mat[rowSums(count_mat) > 0, , drop=FALSE]
  colnames(count_mat) <- make.unique(colnames(count_mat))
  
  msg("Counts dim: %d genes x %d samples", nrow(count_mat), ncol(count_mat))
  count_mat
}

# sample: Line_Part_Time_Rep, e.g. B48_d_3m_1
make_traits_from_sample <- function(sample_names){
  sp <- strsplit(sample_names, "_", fixed = TRUE)
  mat <- do.call(rbind, lapply(sp, function(x){
    if (length(x) < 4) c(NA, NA, NA, NA) else x[1:4]
  }))
  colnames(mat) <- c("Line","Part","Time","Rep")
  trait <- as.data.frame(mat, stringsAsFactors = FALSE)
  rownames(trait) <- sample_names
  
  trait$Rep  <- suppressWarnings(as.integer(trait$Rep))
  trait$Line <- factor(trait$Line)
  trait$Part <- factor(trait$Part, levels=c("d","m","u"))
  trait$Time <- factor(trait$Time, levels=c("3m","6m","9m"))
  
  mm <- model.matrix(~ 0 + Line + Part + Time, data = trait)
  mm <- as.data.frame(mm)
  rownames(mm) <- sample_names
  
  cbind(trait, mm)
}

safe_cor <- function(x, y){
  x <- as.data.frame(x)
  y <- as.data.frame(y)
  x <- x[, sapply(x, is.numeric), drop=FALSE]
  y <- y[, sapply(y, is.numeric), drop=FALSE]
  cor(x, y, use="p")
}

cor_pmatrix_by_traitN <- function(cmat, traitNum){
  pmat <- matrix(NA_real_, nrow=nrow(cmat), ncol=ncol(cmat))
  rownames(pmat) <- rownames(cmat)
  colnames(pmat) <- colnames(cmat)
  for (j in seq_len(ncol(cmat))) {
    n_j <- sum(!is.na(traitNum[, j]))
    pmat[, j] <- corPvalueStudent(cmat[, j], n_j)
  }
  pmat
}

plot_trait_heatmap <- function(MEs, traitNum, prefix){
  if (is.null(traitNum) || ncol(traitNum) == 0) return(invisible(NULL))
  cmat <- safe_cor(MEs, traitNum)
  pmat <- cor_pmatrix_by_traitN(cmat, traitNum)
  
  write.csv(cmat, file=paste0(prefix, "_cor.csv"), quote=FALSE)
  write.csv(pmat, file=paste0(prefix, "_pvalue.csv"), quote=FALSE)
  
  textMatrix <- paste(signif(cmat, 2), "\n(", signif(pmat, 1), ")", sep="")
  dim(textMatrix) <- dim(cmat)
  
  pdf(paste0(prefix, "_heatmap.pdf"), width=10, height=8)
  par(mar=c(6, 10, 3, 3))
  labeledHeatmap(
    Matrix = cmat,
    xLabels = colnames(traitNum),
    yLabels = colnames(MEs),
    ySymbols = colnames(MEs),
    colorLabels = FALSE,
    colors = blueWhiteRed(50),
    textMatrix = textMatrix,
    setStdMargins = FALSE,
    cex.text = 0.6,
    zlim = c(-1, 1),
    main = prefix
  )
  dev.off()
  
  invisible(list(cor=cmat, p=pmat))
}


vsd <- vst(dds, blind=TRUE)
expr <- assay(vsd)

gene_var <- apply(expr, 1, var, na.rm=TRUE)
ord <- order(gene_var, decreasing=TRUE)
ng <- nrow(expr)
target_n <- min(max(opt$minGene, min(ng, opt$maxGene)), ng)
expr <- expr[ord[1:target_n], , drop=FALSE]
msg("After variance selection: %d genes x %d samples", nrow(expr), ncol(expr))


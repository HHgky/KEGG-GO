# ---- 7) kME vs GS plots (SVG, TopN modules per trait) ----
TopN <- 10
kme_dir <- file.path("HubGenes_byTrait", "kME_vs_GS_plots_svg_TNR_Bold")
dir.create(kme_dir, showWarnings = FALSE, recursive = TRUE)

get_top_modules <- function(trait_name){
  if (!exists("traitNum_all") || !trait_name %in% colnames(traitNum_all)) return(character(0))
  v <- as.numeric(cor(MEs, traitNum_all[[trait_name]], use = "p"))
  names(v) <- colnames(MEs)
  v <- v[!is.na(v)]
  names(sort(abs(v), decreasing = TRUE))[1:min(TopN, length(v))]
}


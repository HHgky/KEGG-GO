dir.create("HubGenes_byTrait", showWarnings=FALSE)

for (tr in traits_of_interest) {
  msg("Hub analysis for trait: %s", tr)
  if (!tr %in% colnames(traitNum_all)) next
  trait_vec <- traitNum_all[[tr]]
  n_eff <- sum(!is.na(trait_vec))
  if (n_eff < 5) next
  
  GS <- as.numeric(cor(datExpr, trait_vec, use="p"))
  GS_p <- as.numeric(corPvalueStudent(cor(datExpr, trait_vec, use="p"), n_eff))
  
  gene_info <- data.frame(
    Gene = colnames(datExpr),
    Module = moduleColors,
    GS = GS,
    GS_pvalue = GS_p,
    stringsAsFactors=FALSE
  )
  gene_info <- cbind(gene_info, datKME[gene_info$Gene, , drop=FALSE])
  write.csv(gene_info, file=file.path("HubGenes_byTrait", paste0("gene_info_", tr, ".csv")),
            row.names=FALSE, quote=FALSE)
  
  mods <- sort(unique(moduleColors))
  for (mod in mods) {
    if (mod == "grey") next
    kME_col <- paste0("kME", mod)
    if (!kME_col %in% colnames(gene_info)) next
    
    sub <- gene_info[gene_info$Module == mod, , drop=FALSE]
    if (nrow(sub) < 10) next
    
    hub <- sub[abs(sub[[kME_col]]) > 0.7 & abs(sub$GS) > 0.2 & sub$GS_pvalue < 0.05, , drop=FALSE]
    hub <- hub[order(-abs(hub[[kME_col]]), -abs(hub$GS)), , drop=FALSE]
    
    if (nrow(hub) > 0) {
      write.csv(hub,
                file=file.path("HubGenes_byTrait", paste0("hub_", mod, "_", tr, ".csv")),
                row.names=FALSE, quote=FALSE)
    }
  }

  traitData2$PlantHeight  <- ph$PlantHeight[match(plant_id_trait, ph$PlantID)]
  traitData2$StemDiameter <- ph$StemDiameter[match(plant_id_trait, ph$PlantID)]
  
  miss_h <- sum(is.na(traitData2$PlantHeight))
  miss_d <- sum(is.na(traitData2$StemDiameter))
  msg("Phenotype matched. Missing PlantHeight=%d; Missing StemDiameter=%d", miss_h, miss_d)
